/* 全站設定 */
.body-style {
    width: 100%; height: 100%;
}

/* 左上角 (返回鍵 + 任務欄) */
.top-left-ui {
    position: absolute;
    top: 30px; left: 30px;
    flex-direction: column;
    align-items: flex-start;
    z-index: 50;
}

.back-pill-btn {
    flex-direction: row;
    align-items: center;
    padding: 0 14px;
    height: 44px;
    border-radius: 22px;
    background-image: url("project://database/Assets/Image/UIPanel/Practice/back_default.png");
    border-width: 0;
    margin-bottom: 14px;
    transition-property: scale, translate;
    transition-duration: 0.12s;
}
.back-arrow { font-size: 18px; color: #8b5525; margin-right: 5px; }
.back-label { font-size: 16px; color: #8b5525; -unity-font-style: bold; }

.back-pill-btn:hover {
    scale: 1.05;
    translate: 0 -2px;
    background-image: url("project://database/Assets/Image/UIPanel/Practice/back_hover.png");
}
.back-pill-btn:active {
    scale: 0.98;
    translate: 0 2px;
    background-image: url("project://database/Assets/Image/UIPanel/Practice/back_active.png");
}

/* 任務欄 (Mission Panel) */
.mission-panel { flex-direction: column; }

.mission-task {
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
    width: 150px;
    height: 40px;
    margin-bottom: 12px;
    background-image: url("project://database/Assets/Image/UIPanel/Practice/default-t2.png");
    overflow: hidden;
    /* 變形原點設為左上 */
    transform-origin: left top;
    transition-property: width, height, scale, background-color;
    transition-duration: 0.3s;
}

/* 展開狀態 */
.mission-task.active {
    width: 280px;
    height: 50px;
    scale: 1.05;
    padding: 0;
    background-image: url("project://database/Assets/Image/UIPanel/Practice/active-t2.png");
}

.task-left {
    flex-direction: row;
    align-items: center;       /* 確保標題與描述在同一條水平線上 */
    height: 100%;              /* 撐滿高度以便對齊 */
    padding: 0; /* 確保這裡沒有 left padding */
    margin: 0;
    flex-shrink: 0;
}

.task-title {
    height: 100%;
    margin: 0;
    padding: 0 12px;
    background-image: url("project://database/Assets/Image/UIPanel/Practice/default-t.png");
    color: white;
    -unity-text-align: middle-center;
    font-size: 18px;
}

.task-desc {
    font-size: 15px;
    color: #5F7F8D;
    margin-left: 8px;
    opacity: 0;
    width: 0;
    transition-property: opacity, width;
    transition-duration: 0.2s;
}

.mission-task.active .task-desc { opacity: 1; width: auto; }

.task-progress {
    padding-right: 10px;
    color: #4F7F8D;
}

/* 右上角選單 */
.top-right-menu {
    position: absolute;
    top: 30px; right: 30px;
}

.menu-btn {
    width: 200px; 
    height: 70px;
    border-radius: 30px;
    border-width: 0;
    color: white; 
    font-size: 30px; 
    -unity-font-style: bold;

    background-image: url("project://database/Assets/Image/UIPanel/Practice/blue_default.png");

    transition-property: scale, translate;
    transition-duration: 0.12s;
}

.menu-btn:hover { scale: 1.05; translate: 0 -2px; background-image: url("project://database/Assets/Image/UIPanel/Practice/blue_hover.png"); }
.menu-btn:active { scale: 0.98; translate: 0 2px; background-image: url("project://database/Assets/Image/UIPanel/Practice/blue_active.png");}

/* 右下角 HUD (與之前版本一致) */
.hud-bottom {
    position: absolute;
    bottom: 18px;
    right: 18px;
    align-items: flex-end;
}

.playerbar {
    width: 300px;
    height: 80px;
    flex-direction: row;
    align-items: center;
    padding: 10px 14px;
    border-radius: 40px;
    background-color: rgba(246, 235, 207, 0.95);
    border-width: 2px;
    border-color: rgba(255,255,255,0.8);
}

.avatar-wrap { 
    width: 52px; height: 52px; 
    margin-right: 14px; 
    border-radius: 26px;
    border-width: 3px;
    border-color: rgba(255,255,255,0.9);
    overflow: hidden;

}
.avatar {
    width: 100%; height: 100%;
    -unity-background-scale-mode: scale-and-crop;
}

.player-meta { flex-grow: 1; justify-content: center; }
.player-name { font-size: 16px; -unity-font-style: bold; color: #8b6a2b; margin-bottom: 10px; margin-top: -6px;}

.level-line { flex-direction: row; align-items: center; }
.level-bubble {
    width: 26px; height: 26px; border-radius: 13px;
    background-color: #4fc7ff; border-width: 2px; border-color: rgba(255,255,255,0.9);
    color: #ffffff; font-size: 12px; -unity-font-style: bold; -unity-text-align: middle-center;
    z-index: 2;
    position: absolute;
    left: 0;
}

.level-track { width: 120px; height: 10px; background-color: #ffffff; border-radius: 5px; overflow: hidden; margin-left: 20px; }
.level-fill { height: 100%; background-color: #3fafff; border-radius: 5px; }

.icon-btn {
    width: 38px; height: 38px; border-radius: 15px;
    background-color: #ffffff; border-width: 0;
    align-items: center; justify-content: center;
}
.mic-icon { width: 20px; height: 20px; display: none; }
.mic-btn {
    transition-property: translate, scale;
    transition-duration: 0.12s;
}
.mic-btn:hover { translate: 0 -1.5px; }
.mic-btn:active { translate: 0 1.5px; }
.mic-btn.is-open .mic-open { display: flex; background-image: url("project://database/Assets/Image/UIPanel/CreateRoom/mic-open.png"); }
.mic-btn.is-off .mic-off { display: flex; background-image: url("project://database/Assets/Image/UIPanel/CreateRoom/mic-off.png"); }